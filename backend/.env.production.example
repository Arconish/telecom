# Fallback non-secret production configuration.
# The MVP EC2 host normally uses /opt/app/shared/backend.env created by infra.
# Secrets (SECRET_KEY, DB_PASSWORD) are fetched from
# AWS Parameter Store at runtime via start.sh:
#   /nw-monitor/mvp/backend/secret_key
#   /nw-monitor/mvp/backend/db_password
# Admin bootstrap values are fetched from Parameter Store by deploy.sh:
#   /nw-monitor/mvp/admin/username
#   /nw-monitor/mvp/admin/email
#   /nw-monitor/mvp/admin/password

APP_ENV=production
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=network_ops_db
DB_USER=app
DB_PASSWORD=

ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=https://demo.monitor.buildwithhein.com
BACKEND_URL=https://demo.monitor.buildwithhein.com/api
ALLOWED_ORIGINS=https://demo.monitor.buildwithhein.com
